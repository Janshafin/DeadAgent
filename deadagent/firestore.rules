rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User-scoped data: only the authenticated owner can read/write
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Testaments: only the authenticated owner can read/write their testament
    match /testaments/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
